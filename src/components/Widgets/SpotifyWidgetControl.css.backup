.widget-control-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #1a1f2e 0%, #252b3d 100%);
  padding: 20px;
}

.widget-control-header {
  max-width: 1000px;
  margin: 0 auto 20px;
  color: white;
}

.widget-control-header h1 {
  font-size: 1.8rem;
  margin: 10px 0;
  font-weight: 600;
}

.back-button {
  background: rgba(255, 255, 255, 0.1);
  color: #f3f4f6;
  border: 1px solid rgba(255, 255, 255, 0.2);\n  padding: 8px 16px;
  border-radius: 8px;
  cursor: pointer;
  font-size: 14px;
  font-weight: 500;
  transition: all 0.3s ease;
}

.back-button:hover {
  background: rgba(255, 255, 255, 0.2);
  transform: translateX(-2px);
}

.widget-control-content {
  max-width: 1000px;
  margin: 0 auto;
  display: grid;
  gap: 20px;
}

.widget-url-section,
.widget-settings-section {
  background: rgba(26, 27, 46, 0.8);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 12px;
  padding: 20px;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
}

.widget-url-section h3,
.widget-settings-section h3 {
  font-size: 1.2rem;
  margin-bottom: 15px;
  color: #f3f4f6;
  font-weight: 600;
}

.widget-url-section p,
.widget-settings-section p {
  color: #9ca3af;
  font-size: 14px;
}

.url-box {
  display: flex;
  gap: 10px;
  margin: 20px 0;
}

.url-box input {
  flex: 1;
  padding: 10px 12px;
  background: rgba(0, 0, 0, 0.3);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 8px;
  font-family: monospace;
  font-size: 13px;
  color: #f3f4f6;
}

.url-box input:focus {
  outline: none;
  border-color: #667eea;
}

.url-box button {
  padding: 10px 20px;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  font-size: 14px;
}

.url-box button:hover {
  transform: scale(1.05);
}

.obs-instructions {
  background: rgba(0, 0, 0, 0.3);
  border: 1px solid rgba(255, 255, 255, 0.1);
  padding: 15px;
  border-radius: 8px;
  margin-top: 15px;
}

.obs-instructions h4 {
  margin-bottom: 10px;
  color: #f3f4f6;
  font-size: 14px;
  font-weight: 600;
}

.obs-instructions ol {
  margin-left: 20px;
  color: #9ca3af;
  line-height: 1.6;
  font-size: 13px;
}

.setting-group {
  margin-bottom: 18px;
}

.setting-group label {
  display: block;
  font-weight: 600;
  margin-bottom: 8px;
  color: #f3f4f6;
  font-size: 14px;
}

.setting-group input[type="checkbox"] {
  margin-right: 10px;
}

.setting-group select,
.setting-group input[type="range"] {
  width: 100%;
  padding: 10px;
  background: rgba(0, 0, 0, 0.3);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 8px;
  font-size: 14px;
  color: #f3f4f6;
}

.setting-group select:focus {
  outline: none;
  border-color: #667eea;
}

.setting-group select option {
  background: #1a1f2e;
  color: #f3f4f6;
}

.setting-group input[type="range"] {
  padding: 0;
}

.save-button {
  width: 100%;
  padding: 12px;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 8px;
  font-size: 15px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
}

.save-button:hover {
  transform: scale(1.02);
  box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
}

.spotify-connect-section {
  background: rgba(26, 27, 46, 0.8);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 12px;
  padding: 40px 30px;
  text-align: center;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
}

.spotify-connect-section h2 {
  font-size: 1.6rem;
  margin-bottom: 15px;
  color: #f3f4f6;
  font-weight: 600;
}

.spotify-connect-section p {
  font-size: 1rem;
  color: #9ca3af;
  margin-bottom: 25px;
}

.spotify-connect-btn {
  background: #1db954;
  color: white;
  border: none;
  padding: 15px 40px;
  border-radius: 50px;
  font-size: 18px;
  font-weight: 700;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: 12px;
  transition: all 0.3s ease;
  box-shadow: 0 4px 15px rgba(29, 185, 84, 0.3);
}

.spotify-connect-btn:hover {
  background: #1ed760;
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(29, 185, 84, 0.4);
}

.spotify-icon {
  width: 24px;
  height: 24px;
}

.spotify-connected-banner {
  background: linear-gradient(135deg, #1db954 0%, #1ed760 100%);
  color: white;
  padding: 15px 20px;
  border-radius: 12px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30px;
  box-shadow: 0 4px 15px rgba(29, 185, 84, 0.3);
}

.spotify-connected-banner span {
  font-weight: 700;
  font-size: 16px;
}

.disconnect-btn {
  background: rgba(255, 255, 255, 0.2);
  border: 1px solid rgba(255, 255, 255, 0.3);
  color: white;
  padding: 8px 16px;
  border-radius: 6px;
  cursor: pointer;
  font-weight: 600;
  transition: all 0.3s ease;
}

.disconnect-btn:hover {
  background: rgba(255, 255, 255, 0.3);
}

/* Layout Options */
.layout-options {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: 15px;
  margin-top: 10px;
}

.layout-option {
  background: rgba(0, 0, 0, 0.3);
  border: 2px solid rgba(255, 255, 255, 0.2);
  border-radius: 12px;
  padding: 12px;
  cursor: pointer;
  transition: all 0.3s ease;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}

.layout-option:hover {
  border-color: #667eea;
  transform: translateY(-2px);
}

.layout-option.active {
  border-color: #667eea;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
  box-shadow: 0 4px 15px rgba(102, 126, 234, 0.2);
}

.layout-option span {
  font-weight: 600;
  color: #f3f4f6;
  font-size: 13px;
}

/* Layout Previews */
.layout-preview {
  width: 100%;
  height: 80px;
  background: white;
  border-radius: 8px;
  padding: 10px;
  display: flex;
  align-items: center;
  gap: 10px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

.preview-album {
  width: 40px;
  height: 40px;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 6px;
  flex-shrink: 0;
}

.preview-album.large {
  width: 60px;
  height: 60px;
}

.preview-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.preview-text.wide {
  gap: 8px;
}

.preview-line {
  height: 8px;
  background: #e0e0e0;
  border-radius: 4px;
  width: 100%;
}

.preview-line.short {
  width: 60%;
}

.compact-preview {
  height: 60px;
}

.minimal-preview {
  flex-direction: column;
  justify-content: center;
  padding: 15px;
}

.card-preview {
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 15px;
}

.banner-preview {
  height: 70px;
}

.glass-preview {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.3), rgba(118, 75, 162, 0.3));
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.2);
}

.floating-preview {
  height: 50px;
  padding: 8px;
  background: linear-gradient(90deg, #1db954, #1ed760);
}

.floating-preview .preview-album.small {
  width: 30px;
  height: 30px;
}

.floating-preview .preview-line.thin {
  height: 6px;
}

/* Preview Section */
.widget-preview-section {
  background: rgba(26, 27, 46, 0.8);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 12px;
  padding: 20px;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
}

.widget-preview-section h3 {
  font-size: 1.2rem;
  margin-bottom: 15px;
  color: #f3f4f6;
  font-weight: 600;
}

.preview-container {
  width: 960px;
  height: 540px;
  overflow: hidden;
  border-radius: 8px;
  margin: 0 auto;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.preview-note {
  text-align: center;
  color: #9ca3af;
  margin-top: 15px;
  font-size: 13px;
}

.preview-note {
  text-align: center;
  color: #9ca3af;
  margin-top: 15px;
  font-size: 13px;
}

.preview-button {
  width: 100%;
  padding: 15px;
  background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
  color: white;
  border: none;
  border-radius: 8px;
  font-size: 16px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  margin-top: 15px;
}

.preview-button:hover {
  transform: scale(1.02);
  box-shadow: 0 5px 15px rgba(46, 204, 113, 0.4);
}
